<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>@ViewData["Title"] - OpenTakRouter</title>
    <link rel="stylesheet" href="/assets/site.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <div class="otr-shell">
        <partial name="_MainNavigation" />
        <main class="otr-main">
            <header class="otr-page-header">
                <div>
                    <h1 class="otr-page-title">@ViewData["Title"]</h1>
                    <p class="otr-page-subtitle">Cursor-on-Target routing, federation, and operator visibility.</p>
                </div>
            </header>
            <div class="otr-page-body">
                @RenderBody()
            </div>
        </main>
    </div>
    <script type="module" src="/assets/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
