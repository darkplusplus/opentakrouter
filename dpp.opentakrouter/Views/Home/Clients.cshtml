@{
    ViewData["Title"] = "Clients";
}

<section class="otr-card otr-table-wrap">
    <table class="otr-table">
        <thead>
            <tr>
                <th>Callsign</th>
                <th>Device</th>
                <th>Platform</th>
                <th>Version</th>
                <th>Last Seen</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var client in ViewData["clients"] as IEnumerable<Client>)
            {
                <tr>
                    <td>@client.Callsign</td>
                    <td>@client.Device</td>
                    <td>@client.Platform</td>
                    <td>@client.Version</td>
                    <td>@client.LastSeen.ToUniversalTime().ToString("u")</td>
                    <td>
                        <button type="button" class="otr-button" disabled>Disconnect</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>
