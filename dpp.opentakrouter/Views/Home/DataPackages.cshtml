@{
    ViewData["Title"] = "Data Packages";
}

<section class="otr-card otr-table-wrap" data-page="datapackages">
    <div style="display:flex;justify-content:space-between;gap:1rem;align-items:flex-start;margin-bottom:1rem;flex-wrap:wrap;">
        <div class="otr-qr-card" data-role="itak-qr">
            <strong>iTAK Quick Connect</strong>
            <div data-role="itak-qr-code" style="margin-top:0.75rem;"></div>
            <p data-role="itak-qr-status" style="margin-top:0.75rem;">Generating QR payload...</p>
        </div>
        <a class="otr-button" href="/Marti/api/provisioning/serverpackage">Download Server Package</a>
    </div>
    <table class="otr-table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Timestamp</th>
                <th>Uploader</th>
                <th>Size</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var package in ViewData["datapackages"] as IEnumerable<DataPackage>)
            {
                <tr>
                    <td>@package.UID</td>
                    <td>@package.Name</td>
                    <td>@package.SubmissionDateTime.ToUniversalTime().ToString("u")</td>
                    <td>@package.SubmissionUser</td>
                    <td>@package.Size</td>
                    <td>
                        <a class="otr-button" href="/Marti/sync/content?hash=@package.Hash">Download</a>
                        <button type="button" class="otr-button" disabled>Delete</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</section>
