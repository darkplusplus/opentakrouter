@{
    ViewData["Title"] = "Map";
}
<div class="otr-map-layout" data-page="map" data-ws-port="@ViewData["ws-port"]">
    <section class="otr-card otr-map-panel">
        <div id="map" class="otr-map"></div>
    </section>
    <aside class="otr-card otr-operator-panel">
        <section class="otr-panel-section">
            <h2 class="otr-panel-heading">Network Picture</h2>
            <div class="otr-kpis">
                <div class="otr-kpi">
                    <span class="otr-kpi__label">Active Tracks</span>
                    <span class="otr-kpi__value" data-role="total-count">0</span>
                </div>
                <div class="otr-kpi">
                    <span class="otr-kpi__label">Active Sources</span>
                    <span class="otr-kpi__value" data-role="source-count">0</span>
                </div>
            </div>
            <p>
                <span class="otr-status-pill" data-role="socket-status" data-tone="pending">connecting</span>
            </p>
        </section>
        <section class="otr-panel-section">
            <h2 class="otr-panel-heading">Selected Track</h2>
            <dl class="otr-detail-grid">
                <dt>Callsign</dt>
                <dd data-role="selected-callsign">Waiting for feed</dd>
                <dt>Type</dt>
                <dd data-role="selected-type">Unknown</dd>
                <dt>Source</dt>
                <dd data-role="selected-source">Unknown</dd>
                <dt>Position</dt>
                <dd data-role="selected-latlon">0.00000, 0.00000</dd>
                <dt>Updated</dt>
                <dd data-role="selected-updated">Unknown</dd>
            </dl>
        </section>
        <section class="otr-panel-section">
            <h2 class="otr-panel-heading">Recent Feed</h2>
            <div class="otr-feed" data-role="event-feed">
                <p class="otr-empty">Waiting for events.</p>
            </div>
        </section>
    </aside>
</div>
