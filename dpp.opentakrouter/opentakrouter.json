{
    "AllowedHosts": "*",
    "server": {
        // the data directory where the database file is located.
        // defaults to the executable location.
        //"data": "%appdata%/opentakrouter",

        // persist messages to the local database. on by default.
        // in extreme cases this may increase throughput slightly.
        "persist_messages": true,

        "storage": {
            // sqlite or postgres
            "provider": "sqlite",
            "sqlite": {
                "path": "opentakrouter.db"
            },
            "postgres": {
                "connectionString": ""
            }
        },

        // set the server name. this is used for api/federation functionality.
        // defaults to the hostname.
        //"name":  ""

        // set the externally reachable hostname or ip. this is required for
        // generated enrollment packages so EUDs receive a usable connect string.
        //"public_endpoint": "tak.example.com",

        "provisioning": {
            "packageName": "OpenTAKRouter",
            "serverDescription": "OpenTAKRouter",
            "callsign": "CALLSIGN",
            "team": "Blue",
            "role": "Team Member",
            "trustStoreCertificate": "/certs/ca.crt",
            "trustStorePassword": "",
            "clientCertificate": "/certs/client.p12",
            "clientCertificatePassword": "",
            "onReceiveDelete": true
        },

        // the api interface configuration
        "api": {
            "port": 8443,
            "swagger": true,
            "ssl": true,
            "cert": "/certs/tls.crt",
            "key": "/certs/tls.key",
            "passphrase": ""
        },
        "websockets": {
            "enabled": true,
            "port": 5000,

            "ssl": false,
            "cert": "server.p12",
            "key": "",
            "passphrase": "atakatak"
        },

        // the tak protocol configurations
        "tak": {
            "tcp": {
                "enabled": false,
                "port": 58087
            },
            "tls": {
                "enabled": true,
                "port": 8089,
                "cert": "/certs/tls.crt",
                "key": "/certs/tls.key",
                "passphrase": "atakatak"
            }
        },
        "links": [
            // normalized TAK link model. when present, this takes precedence over
            // the legacy `server.tak.*` and `server.peers` settings above.
            // {
            //     "name": "atak-listener",
            //     "enabled": true,
            //     "role": "listen",
            //     "transport": "tls",
            //     "port": 8089,
            //     "cert": "/certs/tls.crt",
            //     "key": "/certs/tls.key",
            //     "protocol": "xml"
            // },
            // {
            //     "name": "regional-peer",
            //     "enabled": true,
            //     "role": "connect",
            //     "transport": "tcp",
            //     "address": "otr.example.net",
            //     "port": 58087,
            //     "mode": "duplex",
            //     "protocol": "prefer-protobuf"
            // }
        ],
        "routing": {
            "inbound": [
            ],
            "outbound": [
            ]
        },
        "peers": [
        ]
    }
}
