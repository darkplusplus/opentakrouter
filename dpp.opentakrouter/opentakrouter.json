{
    "AllowedHosts": "*",
    "server": {
        // the data directory where the database file is located.
        // defaults to the executable location.
        //"data": "%appdata%/opentakrouter",

        // persist messages to the local database. on by default.
        // in extreme cases this may increase throughput slightly.
        "persist_messages": true,

        // set the server name. this is used for api/federation functionality.
        // defaults to the hostname.
        //"name":  ""

        // the api interface configuration
        "api": {
            "port": 8080,
            "swagger": true,

            "ssl": false,
            "cert": "server.p12",
            "passphrase": "atakatak"
        },
        "websockets": {
            "enabled": true,
            "port": 5000,

            "ssl": false,
            "cert": "server.p12",
            "passphrase": "atakatak"
        },

        // the tak protocol configurations
        "tak": {
            "tcp": {
                "enabled": true,
                "port": 58087
            },
            "tls": {
                "enabled": false,
                "port": 58089,
                "cert": "server.p12",
                "passphrase": "atakatak"
            }
        },
        "links": [
            // normalized TAK link model. when present, this takes precedence over
            // the legacy `server.tak.*` and `server.peers` settings above.
            // {
            //     "name": "atak-listener",
            //     "enabled": true,
            //     "role": "listen",
            //     "transport": "tcp",
            //     "port": 58087,
            //     "protocol": "xml"
            // },
            // {
            //     "name": "regional-peer",
            //     "enabled": true,
            //     "role": "connect",
            //     "transport": "tcp",
            //     "address": "otr.example.net",
            //     "port": 58087,
            //     "mode": "duplex",
            //     "protocol": "prefer-protobuf"
            // }
        ],
        "routing": {
            "inbound": [
            ],
            "outbound": [
            ]
        },
        "peers": [
        ]
    }
}
